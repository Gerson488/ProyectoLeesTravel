    tools:layout="@layout/fragment_home">

    <action
        android:id="@+id/action_home_to_myTrips"
        app:destination="@id/myTripsFragment"
        app:enterAnim="@anim/nav_default_enter_anim"
        app:exitAnim="@anim/nav_default_exit_anim" />
</fragment>

    <fragment
        android:id="@+id/myTripsFragment"
        android:name="com.roxcode.leestravelcruises.ui.view.MyTripsFragment"
        android:label="Mis Viajes Asignados"
        tools:layout="@layout/fragment_my_trips" />

    <fragment
        android:id="@+id/newsFragment"
        android:name="com.roxcode.leestravelcruises.ui.view.PublicPublicationFragment"
        android:label="Noticias"
        tools:layout="@layout/fragment_public_publications" />
    <fragment
        android:id="@+id/profileFragment"
        android:name="com.roxcode.leestravelcruises.ui.view.ProfileFragment"
        android:label="Mi Perfil"
        tools:layout="@layout/fragment_profile" />

</navigation>