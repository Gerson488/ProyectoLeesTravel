<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp"
    app:strokeWidth="0dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="16dp">

        <ImageView
            android:id="@+id/ivTripPhoto"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:scaleType="centerCrop"
            android:src="@drawable/bg_cruise"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvBadgeDestino"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="12dp"
            android:background="@drawable/shape_badge_yellow"
            android:paddingHorizontal="12dp"
            android:paddingVertical="4dp"
            android:text="Punta Cana"
            android:textColor="@color/black"
            android:textSize="12sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvBadgeEstado"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="12dp"
            android:background="@drawable/shape_badge_blue"
            android:paddingHorizontal="12dp"
            android:paddingVertical="4dp"
            android:text="En Curso"
            android:textColor="@color/white"
            android:textSize="12sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvBadgePasajeros"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/shape_badge_dark_trans"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:text="125 pasajeros"
            android:textColor="@color/white"
            android:textSize="11sp"
            app:layout_constraintBottom_toBottomOf="@id/ivTripPhoto"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/tvBadgeFecha"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="12dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/shape_badge_light_blue"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:text="Jueves 12 de Marzo"
            android:textColor="@color/white"
            android:textSize="11sp"
            app:layout_constraintBottom_toBottomOf="@id/ivTripPhoto"
            app:layout_constraintEnd_toEndOf="parent" />

        <ImageView
            android:id="@+id/ivIconoBarco"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginStart="16dp"
            android:layout_marginTop="12dp"
            android:src="@drawable/ic_ship"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/ivTripPhoto" />

        <TextView
            android:id="@+id/tvTripTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="16dp"
            android:text="Maria de los Angeles - Punta cana..."
            android:textColor="@color/lees_blue_dark"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@id/ivIconoBarco"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/ivIconoBarco"
            app:layout_constraintTop_toTopOf="@id/ivIconoBarco" />

        <TextView
            android:id="@+id/tvTripSubtitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Maria de los ángeles"
            android:textColor="@color/lees_text_gray"
            android:textSize="14sp"
            app:layout_constraintEnd_toEndOf="@id/tvTripTitle"
            app:layout_constraintStart_toStartOf="@id/tvTripTitle"
            app:layout_constraintTop_toBottomOf="@id/tvTripTitle" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>