<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:strokeWidth="0dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cvPublicationThumbnail"
            android:layout_width="60dp"
            android:layout_height="60dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/ivPublicationThumbnail"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:background="#E0E0E0" />
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/tvMediaCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="5"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@id/cvPublicationThumbnail"
            app:layout_constraintEnd_toEndOf="@id/cvPublicationThumbnail"
            app:layout_constraintStart_toStartOf="@id/cvPublicationThumbnail"
            app:layout_constraintTop_toTopOf="@id/cvPublicationThumbnail" />

        <TextView
            android:id="@+id/tvPublicationTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="Saliendo del aeropuerto"
            android:textColor="#1A1A1A"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/cvPublicationThumbnail"
            app:layout_constraintTop_toTopOf="@id/cvPublicationThumbnail" />

        <TextView
            android:id="@+id/tvStatusBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_badge_outline_blue"
            android:paddingHorizontal="8dp"
            android:paddingVertical="2dp"
            android:text="publicado"
            android:textColor="#0000FF"
            android:textSize="12sp"
            app:layout_constraintStart_toStartOf="@id/tvPublicationTitle"
            app:layout_constraintTop_toBottomOf="@id/tvPublicationTitle" />

        <TextView
            android:id="@+id/tvLocationBadge"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_badge_outline_light_blue"
            android:paddingHorizontal="8dp"
            android:paddingVertical="2dp"
            android:text="Perú - Lima"
            android:textColor="#00BCD4"
            android:textSize="12sp"
            android:maxLines="1"
            android:ellipsize="end"
            app:layout_constrainedWidth="true"
            app:layout_constraintHorizontal_bias="0.0"
            app:layout_constraintBottom_toBottomOf="@id/tvStatusBadge"
            app:layout_constraintStart_toEndOf="@id/tvStatusBadge"
            app:layout_constraintEnd_toStartOf="@id/tvPublicationDate"
            app:layout_constraintTop_toTopOf="@id/tvStatusBadge" />

        <TextView
            android:id="@+id/tvPublicationDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_badge_yellow"
            android:paddingHorizontal="8dp"
            android:paddingVertical="2dp"
            android:text="12/11/2025"
            android:textColor="#FF9800"
            android:textSize="12sp"
            app:layout_constraintBottom_toBottomOf="@id/tvStatusBadge"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/tvStatusBadge" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>