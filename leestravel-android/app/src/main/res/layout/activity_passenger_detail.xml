<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:elevation="0dp"
        app:layout_constraintTop_toTopOf="parent"
        tools:layout_editor_absoluteX="16dp">

        <include
            android:id="@+id/includeToolbar"
            layout="@layout/toolbar_main" />
    </com.google.android.material.appbar.AppBarLayout>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardPassengerHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="12dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="6dp"
        app:strokeWidth="0dp"
        app:layout_constraintTop_toBottomOf="@id/appBarLayout">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="24dp">

            <TextView
                android:id="@+id/tvSubtitleHeader"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Información de"
                android:textSize="13sp"
                android:alpha="0.6"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tvPassengerNameHeader"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Nombre del Pasajero"
                android:textColor="#1A1A1A"
                android:textSize="22sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvSubtitleHeader" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal"
                app:layout_constraintTop_toBottomOf="@id/tvPassengerNameHeader">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="#E8EAF6"
                    app:cardCornerRadius="12dp"
                    app:strokeWidth="0dp">
                    <TextView
                        android:id="@+id/tvRoleHeader"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="6dp"
                        android:text="Pasajero"
                        android:textColor="#002395"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </com.google.android.material.card.MaterialCardView>

                <View android:layout_width="12dp" android:layout_height="1dp" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="#E8EAF6"
                    app:cardCornerRadius="12dp"
                    app:strokeWidth="0dp">
                    <TextView
                        android:id="@+id/tvAgeHeader"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="6dp"
                        android:text="-- años"
                        android:textColor="#002395"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/tabBarContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="20dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="2dp"
        app:strokeWidth="0dp"
        app:layout_constraintTop_toBottomOf="@id/cardPassengerHeader">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal">
            <Button
                android:id="@+id/btnTabGeneral"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="General"
                android:textAllCaps="false"
                android:textColor="#002395"
                app:cornerRadius="0dp" />
            <Button
                android:id="@+id/btnTabMedical"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="🚑 Médico"
                android:textAllCaps="false"
                android:textColor="#666666"
                app:cornerRadius="0dp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:clipToPadding="false"
        android:paddingBottom="32dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tabBarContainer">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="24dp"
            android:paddingTop="16dp">

            <LinearLayout
                android:id="@+id/layoutGeneralInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="visible">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Nombres completos" android:textSize="13sp" android:textColor="#666666" android:layout_marginStart="4dp"/>
                <include layout="@layout/item_detail_field" android:id="@+id/fieldFullName" />

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Fecha de nacimiento" android:layout_marginTop="16dp" android:textSize="13sp" android:textColor="#666666" android:layout_marginStart="4dp"/>
                <include layout="@layout/item_detail_field" android:id="@+id/fieldBirth" />

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Nacionalidad" android:layout_marginTop="16dp" android:textSize="13sp" android:textColor="#666666" android:layout_marginStart="4dp"/>
                <include layout="@layout/item_detail_field" android:id="@+id/fieldCountry" />

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Número de Documento" android:layout_marginTop="16dp" android:textSize="13sp" android:textColor="#666666" android:layout_marginStart="4dp"/>
                <include layout="@layout/item_detail_field" android:id="@+id/fieldDoc" />

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Género" android:layout_marginTop="16dp" android:textSize="13sp" android:textColor="#666666" android:layout_marginStart="4dp"/>
                <include layout="@layout/item_detail_field" android:id="@+id/fieldGender" />

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Tipo de Documento" android:layout_marginTop="16dp" android:textSize="13sp" android:textColor="#666666" android:layout_marginStart="4dp"/>
                <include layout="@layout/item_detail_field" android:id="@+id/fieldDocType" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutMedicalInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardMedicalConditions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="16dp"
                    app:cardBackgroundColor="#FFF5F5"
                    app:strokeColor="#FFCDD2"
                    app:strokeWidth="1dp">
                    <TextView
                        android:id="@+id/tvMedicalConditions"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="20dp"
                        android:text="Cargando información médica..."
                        android:textColor="#B71C1C"
                        android:textSize="15sp"
                        android:lineSpacingExtra="4dp" />
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnNewIncident"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="20dp"
                    android:text="⚠️ Anotar Percance Médico"
                    android:textAllCaps="false"
                    android:textColor="@android:color/white"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    app:backgroundTint="#002395"
                    app:cornerRadius="14dp"
                    android:visibility="gone" />
            </LinearLayout>
        </FrameLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>